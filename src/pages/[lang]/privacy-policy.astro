---
import BaseLayout from '../../layouts/BaseLayout.astro';
import th from '../../i18n/th.json';
import en from '../../i18n/en.json';
import zh from '../../i18n/zh.json';
import { languagesList } from '../../i18n/ui';

export function getStaticPaths() {
  return languagesList.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const m = { th, en, zh }[lang];
const legal = m.legal.privacy;
const meta = { title: `${legal.title} — ${m.footer.brand.name}`, description: legal.title };
---
<BaseLayout lang={lang} title={meta.title} description={meta.description} messages={m}>
  <main class="mx-auto max-w-3xl px-4 py-24">
    <a href={`/${lang}/`} class="text-amber-600 hover:underline">← {m.header.home}</a>
    <h1 class="mt-4 text-3xl font-bold text-stone-800">{legal.title}</h1>
    <p class="mt-2 text-sm text-stone-500">{legal.updated}</p>
    <div class="mt-6 space-y-6 text-stone-700 leading-relaxed">
      {legal.sections.map((s) => (
        <section>
          <h2 class="text-lg font-semibold text-stone-800">{s.h}</h2>
          <p class="mt-1">{s.p}</p>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
