---
import BaseLayout from '../../layouts/BaseLayout.astro';
import th from '../../i18n/th.json';
import en from '../../i18n/en.json';
import zh from '../../i18n/zh.json';
import { languagesList } from '../../i18n/ui';

export function getStaticPaths() {
  return languagesList.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const m = { th, en, zh }[lang];
const legal = m.legal.cookies;
const meta = { title: `${legal.title} — ${m.footer.brand.name}`, description: legal.title };
---
<BaseLayout lang={lang} title={meta.title} description={meta.description} messages={m}>
  <main class="mx-auto max-w-3xl px-4 py-24">
    <a href={`/${lang}/`} class="text-amber-600 hover:underline">← {m.header.home}</a>
    <h1 class="mt-4 text-3xl font-bold text-stone-800">{legal.title}</h1>
    <p class="mt-2 text-sm text-stone-500">{legal.updated}</p>
    <p class="mt-4 text-stone-700 leading-relaxed">{legal.intro}</p>
    <div class="mt-6 space-y-4">
      {legal.categories.map((c) => (
        <section class="rounded-xl border border-stone-200 p-5">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold text-stone-800">{c.h}</h2>
            <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-700">{c.status}</span>
          </div>
          <p class="mt-2 text-stone-700">{c.p}</p>
          <p class="mt-2 text-sm text-stone-500">{c.sub} · {c.subStatus}</p>
        </section>
      ))}
    </div>
    <p class="mt-6 text-sm text-stone-500">{legal.consent}</p>
  </main>
</BaseLayout>
