---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getI18n } from '../i18n/ui';

interface Props {
  type: 'privacy' | 'terms' | 'cookies';
}
const { type } = Astro.props;
const { lang, messages } = await getI18n(Astro.url);
const doc = (messages.legal as any)[type];
---
<BaseLayout lang={lang} title={doc.title} description={doc.title} messages={messages}>
  <Header lang={lang} messages={messages} />
  <main class="mx-auto max-w-3xl px-5 py-14 text-ink/85 leading-relaxed">
    <h1 class="font-display text-3xl md:text-4xl text-teak mb-2">{doc.title}</h1>
    <p class="text-sm text-ink/50 mb-8">{doc.updated}</p>

    {type !== 'cookies' && doc.sections.map((s: any) => (
      <section class="mb-8">
        <h2 class="font-display text-xl text-teak mb-2">{s.h}</h2>
        {s.p && <p class="mb-3">{s.p}</p>}
        {s.list && (
          <ul class="list-disc pl-6 space-y-1">
            {s.list.map((li: string) => <li>{li}</li>)}
          </ul>
        )}
      </section>
    ))}

    {type === 'cookies' && (
      <>
        <p class="mb-6">{doc.intro}</p>
        <div class="space-y-4">
          {doc.categories.map((c: any) => (
            <div class="rounded-2xl border border-teak/20 p-5 bg-white/40">
              <div class="flex items-center justify-between gap-3">
                <h2 class="font-display text-lg text-teak">{c.h}</h2>
                <span class={`text-xs px-2 py-1 rounded-full ${c.active ? 'bg-teak/15 text-teak' : 'bg-ink/10 text-ink/60'}`}>{c.status}</span>
              </div>
              <p class="mt-2 text-sm text-ink/75">{c.p}</p>
              {c.sub && (
                <div class="mt-2 flex items-center justify-between text-sm text-ink/60">
                  <span>{c.sub}</span>
                  <span class={c.active ? 'text-teak' : 'text-ink/50'}>{c.subStatus}</span>
                </div>
              )}
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-ink/60">{doc.consent}</p>
        <div class="mt-6 flex gap-3">
          <button type="button" class="rounded-full bg-teak px-5 py-2 text-sm font-medium text-ivory">{doc.save}</button>
          <button type="button" class="rounded-full border border-ink/30 px-5 py-2 text-sm text-ink/80">{doc.rejectAll}</button>
        </div>
      </>
    )}
  </main>
  <Footer lang={lang} messages={messages} />
</BaseLayout>
