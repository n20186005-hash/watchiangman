---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const arch = messages.arch;
---

<section id="arch" class="py-20 bg-sand text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{arch.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{arch.heading}</h2>
    <p class="mt-4 max-w-2xl text-ink/80">{arch.intro}</p>

    <!-- Sacred treasures -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{arch.treasuresTitle}</h3>
    <div class="grid md:grid-cols-2 gap-4">
      {arch.treasures.map((t) => (
        <div class="rounded-2xl border border-gold/25 bg-white/50 p-6">
          <div class="font-display text-gold text-2xl mb-1">{t.tag}</div>
          <h4 class="font-display text-lg text-teak font-semibold">{t.title}</h4>
          <p class="text-sm text-ink/75 mt-2 leading-relaxed">{t.text}</p>
        </div>
      ))}
    </div>

    <!-- Architecture -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{arch.archTitle}</h3>
    <div class="grid md:grid-cols-3 gap-4">
      {arch.architecture.map((a) => (
        <div class="rounded-xl border border-gold/25 bg-white/50 p-5">
          <div class="font-semibold text-teak mb-1">{a.title}</div>
          <p class="text-sm text-ink/75 leading-relaxed">{a.desc}</p>
        </div>
      ))}
    </div>

    <!-- Visiting note -->
    <div class="mt-12 rounded-2xl border border-teak/30 bg-teak/5 p-6">
      <span class="chip text-teak border-teak/40">{arch.noteTag}</span>
      <p class="mt-3 text-ink/80 leading-relaxed">{arch.noteText}</p>
    </div>
  </div>
</section>
