---
import { siteConfig } from '../config';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  messages: Record<string, any>;
}
const { lang, messages } = Astro.props;
const hero = messages.hero;

const main = hero.titleMain as string;
const accent = hero.titleAccent as string;
const parts = main.split(accent);
const heroImg = '/gallery/wat-chiang-man-13.jpg';
const mapsUrl = siteConfig.mapsUrl;
const coordsLabel = hero.coordsLabel;

// Full weather-code labels (all languages); only the current language is shipped per page.
const WEATHER_CODES: Record<number, Record<string, { t: string; s: string }>> = {
  0: { th: { t: 'ท้องฟ้าโปร่งใส', s: 'แดดจัด' }, en: { t: 'Clear sky', s: 'Sunny' }, zh: { t: '晴空', s: '晴' } },
  1: { th: { t: 'โปร่งโล่ง', s: 'ส่วนใหญ่โปร่ง' }, en: { t: 'Mainly clear', s: 'Mostly clear' }, zh: { t: '少云', s: '少云' } },
  2: { th: { t: 'มีเมฆบางส่วน', s: 'มีเมฆบางส่วน' }, en: { t: 'Partly cloudy', s: 'Partly cloudy' }, zh: { t: '局部多云', s: '局部多云' } },
  3: { th: { t: 'เมฆมาก', s: 'เมฆมาก' }, en: { t: 'Overcast', s: 'Overcast' }, zh: { t: '阴', s: '阴' } },
  45: { th: { t: 'หมอก', s: 'หมอก' }, en: { t: 'Fog', s: 'Fog' }, zh: { t: '雾', s: '雾' } },
  48: { th: { t: 'หมอกแข็ง', s: 'หมอก' }, en: { t: 'Rime fog', s: 'Fog' }, zh: { t: '雾凇', s: '雾' } },
  51: { th: { t: 'ฝนปรอยเล็กน้อย', s: 'ฝนปรอย' }, en: { t: 'Light drizzle', s: 'Drizzle' }, zh: { t: '小毛毛雨', s: '毛毛雨' } },
  53: { th: { t: 'ฝนปรอยปานกลาง', s: 'ฝนปรอย' }, en: { t: 'Drizzle', s: 'Drizzle' }, zh: { t: '毛毛雨', s: '毛毛雨' } },
  55: { th: { t: 'ฝนปรอยหนัก', s: 'ฝนปรอย' }, en: { t: 'Dense drizzle', s: 'Drizzle' }, zh: { t: '浓毛毛雨', s: '毛毛雨' } },
  61: { th: { t: 'ฝนตกเล็กน้อย', s: 'ฝนตก' }, en: { t: 'Light rain', s: 'Rain' }, zh: { t: '小雨', s: '雨' } },
  63: { th: { t: 'ฝนตกปานกลาง', s: 'ฝนตก' }, en: { t: 'Rain', s: 'Rain' }, zh: { t: '中雨', s: '雨' } },
  65: { th: { t: 'ฝนตกหนัก', s: 'ฝนตก' }, en: { t: 'Heavy rain', s: 'Rain' }, zh: { t: '大雨', s: '雨' } },
  71: { th: { t: 'หิมะตกเล็กน้อย', s: 'หิมะ' }, en: { t: 'Light snow', s: 'Snow' }, zh: { t: '小雪', s: '雪' } },
  73: { th: { t: 'หิมะตกปานกลาง', s: 'หิมะ' }, en: { t: 'Snow', s: 'Snow' }, zh: { t: '中雪', s: '雪' } },
  75: { th: { t: 'หิมะตกหนัก', s: 'หิมะ' }, en: { t: 'Heavy snow', s: 'Snow' }, zh: { t: '大雪', s: '雪' } },
  80: { th: { t: 'ฝนตกเป็นระยะ', s: 'ฝนตก' }, en: { t: 'Rain showers', s: 'Showers' }, zh: { t: '阵雨', s: '阵雨' } },
  81: { th: { t: 'ฝนตกเป็นระยะปานกลาง', s: 'ฝนตก' }, en: { t: 'Rain showers', s: 'Showers' }, zh: { t: '阵雨', s: '阵雨' } },
  82: { th: { t: 'ฝนตกเป็นระยะหนัก', s: 'ฝนตก' }, en: { t: 'Violent showers', s: 'Showers' }, zh: { t: '强阵雨', s: '阵雨' } },
  95: { th: { t: 'พายุฝนฟ้าคะนอง', s: 'ฟ้าคะนอง' }, en: { t: 'Thunderstorm', s: 'Storm' }, zh: { t: '雷阵雨', s: '雷雨' } },
  96: { th: { t: 'พายุฝนฟ้าคะนองลูกเห็บ', s: 'ฟ้าคะนอง' }, en: { t: 'Thunderstorm', s: 'Storm' }, zh: { t: '雷阵雨', s: '雷雨' } },
  99: { th: { t: 'พายุฝนฟ้าคะนองลูกเห็บหนัก', s: 'ฟ้าคะนอง' }, en: { t: 'Severe thunderstorm', s: 'Storm' }, zh: { t: '强雷阵雨', s: '雷雨' } },
};
const weatherMap = Object.fromEntries(
  Object.entries(WEATHER_CODES).map(([k, v]) => [k, v[lang] ?? v.en])
);
---

<section id="home" class="relative min-h-screen flex items-end overflow-hidden">
  <img src={heroImg} alt={main} class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-t from-teakDeep via-teakDeep/70 to-teak/40"></div>
  <div class="hero-glow absolute inset-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full px-5 pb-16 pt-28 grid lg:grid-cols-12 gap-10 items-end">
    <div class="lg:col-span-7 text-ivory">
      <p class="font-hand text-gold text-xl md:text-2xl mb-3">{hero.eyebrow}</p>
      <h1 class="font-display font-semibold leading-[1.05] text-5xl md:text-7xl lg:text-8xl text-ivory">
        {parts[0]}<span class="gold-text-bright">{accent}</span>{parts[1] ?? ''}
      </h1>
      <p class="mt-6 max-w-xl text-ivory/85 text-lg md:text-xl">{hero.subtitle}</p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a href="#guide" class="inline-flex items-center gap-2 bg-gold text-teak font-semibold px-6 py-3 rounded-full hover:bg-goldBright transition-colors">
          {hero.cta1}
        </a>
        <a href="#food" class="inline-flex items-center gap-2 border border-gold/50 text-ivory px-6 py-3 rounded-full hover:border-goldBright hover:text-goldBright transition-colors">
          {hero.cta2}
        </a>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-5 text-sm text-ivory/80">
        <span class="stars text-lg">★ {hero.rating}</span>
        <span>{hero.reviewCount} Google</span>
        <span class="hidden sm:inline text-ivory/40">·</span>
        <span>{coordsLabel}</span>
      </div>

      <!-- 30-second quick facts -->
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-2 max-w-xl">
        <div class="rounded-xl bg-teakDeep/60 border border-gold/20 px-3 py-2">
          <div class="text-[10px] uppercase tracking-wide text-gold/80">{hero.quickFacts.duration}</div>
          <div class="text-sm font-semibold text-ivory mt-0.5">{hero.quickFacts.durationVal}</div>
        </div>
        <div class="rounded-xl bg-teakDeep/60 border border-gold/20 px-3 py-2">
          <div class="text-[10px] uppercase tracking-wide text-gold/80">{hero.quickFacts.fee}</div>
          <div class="text-sm font-semibold text-ivory mt-0.5">{hero.quickFacts.feeVal}</div>
        </div>
        <div class="rounded-xl bg-teakDeep/60 border border-gold/20 px-3 py-2">
          <div class="text-[10px] uppercase tracking-wide text-gold/80">{hero.quickFacts.dress}</div>
          <div class="text-sm font-semibold text-ivory mt-0.5">{hero.quickFacts.dressVal}</div>
        </div>
      </div>
      <div class="mt-2 rounded-xl bg-gold/15 border border-gold/30 px-4 py-2 max-w-xl text-ivory">
        <span class="text-[10px] uppercase tracking-wide text-gold">{hero.quickFacts.mustSee}</span>
        <span class="text-sm ml-2">{hero.quickFacts.mustSeeVal}</span>
      </div>

      <a href={mapsUrl} target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 text-goldBright hover:text-gold underline-offset-4 hover:underline text-sm">
        {hero.viewLocation}
      </a>

      <!-- wooden park signboard + carousel dots (bottom-left) -->
      <div class="wood-sign mt-8 inline-block max-w-md px-5 py-4">
        <p class="wood-title text-xs font-semibold uppercase tracking-[0.18em]">{hero.boardCategory}</p>
        <p class="wood-title mt-1 font-display text-2xl font-bold leading-tight">{hero.boardTitle}</p>
        <p class="wood-en mt-1 text-sm font-semibold">{hero.boardEn}</p>
      </div>
      <div class="carousel-dots mt-4">
        <span class="dot active"></span>
        <span class="dot"></span>
      </div>
    </div>

    <!-- live weather + sunset planner (static by default; enhanced by API) -->
    <div class="lg:col-span-5">
      <div class="weather-card rounded-2xl p-5 text-ivory shadow-2xl">
        <div class="flex items-center justify-between">
          <span class="text-ivory/70 text-sm">{hero.plannerTitle}</span>
          <span id="weather-status" class="text-xs text-ivory/55">{hero.liveWeather}</span>
        </div>
        <div id="weather-body">
          <div class="flex items-center justify-between mt-2">
            <span id="cur-icon" class="text-2xl">🌦️</span>
            <span class="text-xs text-ivory/55">{hero.plannerNote}</span>
          </div>
          <div class="mt-1 flex items-end gap-3">
            <span id="cur-temp" class="font-display text-5xl font-semibold text-goldBright">{hero.defaultTemp}</span>
            <div class="pb-1">
              <div id="cur-cond" class="text-sm">{hero.defaultCond}</div>
              <div class="text-xs text-ivory/60">💨 <span id="cur-wind">{hero.defaultWind}</span></div>
            </div>
          </div>

          <div class="mt-4 rounded-xl bg-gold/15 border border-gold/30 px-4 py-3">
            <div class="flex items-center justify-between gap-2">
              <span class="text-xs uppercase tracking-wide text-ivory/70">☀️ {hero.sunsetIndexLabel}</span>
            </div>
            <p id="sunset-index" class="mt-1 font-display text-base font-semibold text-goldBright">{hero.sunsetIndexDefault}</p>
          </div>

          <div class="mt-4 pt-4 border-t border-gold/20">
            <p class="font-hand text-gold text-lg">{hero.plannerTitle}</p>
            <p class="text-xs text-ivory/60 mt-0.5">{hero.plannerNote}</p>
            <div class="mt-3 space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-ivory/70">{hero.goldenHourLabel}</span><span id="golden-time" class="font-semibold text-goldBright">{hero.defaultGolden}</span></div>
              <div class="flex justify-between"><span class="text-ivory/70">{hero.sunsetLabel}</span><span id="sunset-time" class="font-semibold text-goldBright">{hero.defaultSunset}</span></div>
              <div class="flex justify-between"><span class="text-ivory/70">{hero.blueHourLabel}</span><span id="blue-time" class="font-semibold text-goldBright">{hero.defaultBlue}</span></div>
              <div class="flex justify-between"><span class="text-ivory/70">{hero.crowdWarningLabel}</span><span class="font-semibold text-ivory">{hero.defaultTip}</span></div>
            </div>
            <p class="text-[11px] text-ivory/50 mt-2">{hero.lightCaption}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ lang, lat: siteConfig.coords.lat, lon: siteConfig.coords.lng, weatherError: hero.weatherError, weatherMap, goldenChanceLabel: hero.goldenChanceLabel }}>
  (function () {
    // Wat Chiang Man — actual coordinates (Old City, Mueang Chiang Mai, Chiang Mai, Northern Thailand)
    const LAT = lat, LON = lon;

    function weatherText(code, mode) {
      const e = weatherMap[code] || weatherMap[3];
      return mode === 'short' ? e.s : e.t;
    }

    // Golden-light probability from the current weather code
    function goldenChance(code) {
      if (code === 0) return 95;
      if (code <= 2) return 85;
      if (code === 3) return 60;
      if (code === 45 || code === 48) return 50;
      if (code >= 51 && code <= 67) return 30;
      if (code >= 71 && code <= 82) return 35;
      if (code >= 95) return 15;
      return 70;
    }

    function iconFor(code) {
      if (code === 0) return '☀️';
      if (code <= 2) return '🌤️';
      if (code === 3) return '☁️';
      if (code === 45 || code === 48) return '🌫️';
      if (code >= 51 && code <= 57) return '🌦️';
      if (code >= 61 && code <= 67) return '🌧️';
      if (code >= 71 && code <= 77) return '❄️';
      if (code >= 80 && code <= 82) return '🌦️';
      if (code >= 95) return '⛈️';
      return '🌡️';
    }

    const pad = (n) => String(n).padStart(2, '0');
    const fmtDate = (d) => pad(d.getHours()) + ':' + pad(d.getMinutes());

    const statusEl = document.getElementById('weather-status');
    const bodyEl = document.getElementById('weather-body');

    fetch(`https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current=temperature_2m,weather_code,wind_speed_10m&daily=weather_code,sunrise,sunset&timezone=Asia/Bangkok&wind_speed_unit=kmh`)
      .then((r) => r.json())
      .then((d) => {
        if (!d || !d.current || !d.daily) throw new Error('bad');
        document.getElementById('cur-temp').textContent = Math.round(d.current.temperature_2m) + '°';
        document.getElementById('cur-cond').textContent = weatherText(d.current.weather_code, 'title');
        document.getElementById('cur-wind').textContent = Math.round(d.current.wind_speed_10m) + ' km/h';
        document.getElementById('cur-icon').textContent = iconFor(d.current.weather_code);

        // Today's sunset-observation index (condition + golden-light chance)
        const idxEl = document.getElementById('sunset-index');
        if (idxEl) {
          idxEl.textContent = iconFor(d.current.weather_code) + ' ' + weatherText(d.current.weather_code, 'short') + ' · ' + goldenChanceLabel + ' ' + goldenChance(d.current.weather_code) + '%';
        }

        // Live sunrise / sunset / blue hour (based on the attraction's actual coordinates)
        const fmt = (date) => pad(date.getHours()) + ':' + pad(date.getMinutes());
        const addMin = (date, m) => new Date(date.getTime() + m * 60000);
        const sr = new Date(d.daily.sunrise[0]);
        const ss = new Date(d.daily.sunset[0]);
        const gEl = document.getElementById('golden-time');
        const sEl = document.getElementById('sunset-time');
        const bEl = document.getElementById('blue-time');
        if (gEl) gEl.textContent = fmt(sr) + ' – ' + fmt(addMin(sr, 90));
        if (sEl) sEl.textContent = fmt(ss);
        if (bEl) bEl.textContent = fmt(addMin(ss, 20)) + ' – ' + fmt(addMin(ss, 50));

        if (bodyEl) bodyEl.classList.remove('hidden');
      })
      .catch(() => {
        // keep static default values; do not break the card layout
        if (bodyEl) bodyEl.classList.remove('hidden');
      });
  })();
</script>
