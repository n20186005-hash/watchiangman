---
import { siteConfig } from '../config';

interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const gallery = messages.gallery;
const alts: string[] = gallery.alts;
const count = alts.length;
const mapsUrl = siteConfig.mapsUrl;
---

<section id="gallery" class="py-20 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{gallery.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{gallery.heading}</h2>
    <p class="mt-4 max-w-2xl text-ink/80">{gallery.intro}</p>
    {gallery.historicalNote && <p class="mt-2 max-w-2xl text-ink/70 italic text-sm">{gallery.historicalNote}</p>}
    <p class="mt-3 text-xs text-ink/50">{gallery.credits}</p>

    <div class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 auto-rows-[180px]">
      {Array.from({ length: count }).map((_, i) => {
        const big = i === 0; // first photo spans larger
        return (
          <div class={`photo-frame rounded-xl ${big ? 'col-span-2 row-span-2' : ''}`}>
            <img
              src={`/gallery/${siteConfig.galleryPrefix}${i + 1}.jpg`}
              alt={alts[i]}
              loading="lazy"
            />
          </div>
        );
      })}
    </div>

    <div class="mt-10 text-center">
      <a href={mapsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-teak border border-gold/50 px-6 py-3 rounded-full hover:bg-gold hover:text-teak transition-colors">
        {gallery.viewLocation}
      </a>
    </div>
  </div>
</section>
