---
import { siteConfig } from '../config';

interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const s = messages.sources;
---

<section id="sources" class="py-16 bg-teakDeep text-ivory">
  <div class="max-w-5xl mx-auto px-5">
    <p class="font-hand text-gold text-xl">{s.label}</p>
    <h2 class="font-display text-3xl md:text-4xl mt-1">{s.heading}</h2>
    <p class="mt-4 text-ivory/75 max-w-2xl">{s.intro}</p>

    <div class="grid md:grid-cols-2 gap-8 mt-8">
      <div>
        <h3 class="font-display text-xl text-goldBright">{s.photoTitle}</h3>
        <ul class="mt-3 space-y-2 text-sm text-ivory/80 list-disc list-inside">
          {s.photoItems.map((it) => (
            <li>
              {it.url
                ? <a href={it.url} class="underline hover:text-goldBright" target="_blank" rel="noopener">{it.text} — {it.linkLabel}</a>
                : it.text}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="font-display text-xl text-goldBright">{s.factTitle}</h3>
        <p class="mt-3 text-sm text-ivory/80">{s.factText}</p>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-gold/30 bg-white/5 p-5">
      <h3 class="font-display text-lg text-goldBright">{s.correctionTitle}</h3>
      <p class="mt-2 text-sm text-ivory/80">{s.correctionText}</p>
      <a
        href={s.correctionMailto}
        class="inline-block mt-3 bg-gold text-teak font-semibold px-5 py-2 rounded-full hover:bg-goldBright transition-colors text-sm"
      >
        {s.correctionCta}
      </a>
    </div>

    <p class="mt-8 text-xs text-ivory/45">© {new Date().getFullYear()} {s.copyright}</p>
  </div>
</section>
