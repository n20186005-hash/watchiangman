---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const about = messages.about;
---

<section id="about" class="py-20 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{about.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{about.heading}</h2>

    <div class="grid lg:grid-cols-12 gap-10 mt-10">
      <div class="lg:col-span-7 space-y-4 text-ink/85">
        <p class="text-lg text-teak font-medium">{about.lead}</p>
        <p>{about.paragraph1}</p>
        <p>{about.paragraph2}</p>
        <blockquote class="border-l-4 border-gold pl-5 italic text-teak font-display text-xl my-6">
          “{about.quote}”
          <footer class="text-sm not-italic text-ink/60 mt-2">— {about.quoteAuthor}</footer>
        </blockquote>
      </div>

      <div class="lg:col-span-5 space-y-8">
        <div class="grid grid-cols-3 gap-3">
          {about.stats.map((s) => (
            <div class="text-center rounded-xl bg-teak text-ivory p-4">
              <div class="font-display text-2xl text-goldBright">{s.value}</div>
              <div class="text-xs text-ivory/70 mt-1 leading-tight">{s.label}</div>
            </div>
          ))}
        </div>

        <div class="space-y-3">
          {about.highlights.map((h) => (
            <div class="flex gap-4 rounded-xl border border-gold/30 bg-white/40 p-4">
              <span class="font-display text-gold text-xl mt-0.5">{h.tag}</span>
              <div>
                <div class="font-semibold text-teak">{h.title}</div>
                <div class="text-sm text-ink/70">{h.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="rounded-xl bg-teakDeep text-ivory p-5">
          <span class="chip text-goldBright border-gold/40">{about.editorTip.tag}</span>
          <p class="mt-3 text-ivory/90">{about.editorTip.text}</p>
          <a href="#guide" class="inline-block mt-3 text-goldBright underline-offset-4 hover:underline">{about.editorTip.ctaLabel} →</a>
        </div>
      </div>
    </div>
  </div>
</section>
